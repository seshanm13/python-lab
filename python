4.# Expense Splitter

expenses = [1200, 850, 1500, 950]

# Total expense
total = sum(expenses)

# Average share
average = total / len(expenses)

# Highest payer
highest_paid = max(expenses)

# Equal contribution
print("Expenses:", expenses)
print("Total Expense:", total)
print("Average Share:", average)
print("Highest Amount Paid:", highest_paid)

print("\nAmount each friend should contribute equally:")

for i in range(len(expenses)):
    difference = expenses[i] - average

    if difference > 0:
        print("Friend", i + 1, "should receive", difference)
    elif difference < 0:
        print("Friend", i + 1, "should pay", abs(difference))
    else:
        print("Friend", i + 1, "is settled")

5.# Pattern Compression

data = [1, 1, 1, 2, 2, 3, 3, 3]

compressed = []

count = 1

for i in range(len(data) - 1):

    if data[i] == data[i + 1]:
        count += 1
    else:
        compressed.append((data[i], count))
        count = 1

# Add last element
compressed.append((data[-1], count))

print("Input:", data)
print("Compressed Output:", compressed)

6.# Mini Shopping Cart System

cart = []
prices = []

while True:

    print("\n1. Add Item")
    print("2. Remove Item")
    print("3. Search Item")
    print("4. Calculate Total Bill")
    print("5. Show Duplicate Items")
    print("6. Display Cart")
    print("7. Exit")

    choice = int(input("Enter your choice: "))

    if choice == 1:
        item = input("Enter item name: ")
        price = float(input("Enter item price: "))

        cart.append(item)
        prices.append(price)

        print("Item added successfully.")

    elif choice == 2:
        item = input("Enter item to remove: ")

        if item in cart:
            index = cart.index(item)
            cart.pop(index)
            prices.pop(index)
            print("Item removed.")
        else:
            print("Item not found.")

    elif choice == 3:
        item = input("Enter item to search: ")

        if item in cart:
            print(item, "is available in cart.")
        else:
            print(item, "not found.")

    elif choice == 4:
        total_bill = sum(prices)
        print("Total Bill =", total_bill)

    elif choice == 5:
        duplicates = []

        for item in cart:
            if cart.count(item) > 1 and item not in duplicates:
                duplicates.append(item)

        print("Duplicate Items:", duplicates)

    elif choice == 6:
        print("Cart Items:", cart)

    elif choice == 7:
        print("Exiting Program...")
        break

    else:
        print("Invalid choice")
